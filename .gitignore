# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# Environment / config
.env
wiregate.yaml

# Database files
*.db
*.db-shm
*.db-wal

# Frontend build output
frontend/dist/
frontend/node_modules/

# Embedded UI directory (populated by `make build` / `make embed-ui`)
# Keep the placeholder files (.gitkeep, README) but ignore everything else
backend/internal/static/ui/*
!backend/internal/static/ui/.gitkeep
!backend/internal/static/ui/README

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ── Development environment ───────────────────────────────────────────────────
# Local dev data (SQLite DB, WireGuard keys/configs for wgdev0)
.dev-data/

# air hot-reload artifacts
backend/.air-tmp/
backend/build-errors.log
