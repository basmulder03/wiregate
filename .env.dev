# WireGate — development environment
# Loaded automatically by air on every backend restart (see backend/.air.toml).
# Paths use ../ since air runs from the backend/ directory.
# DO NOT commit secrets; this file is git-ignored.

# ── Server ────────────────────────────────────────────────────────────────────
WIREGATE_SERVER_PORT=8080
WIREGATE_SERVER_HOST=127.0.0.1
WIREGATE_SERVER_STATIC_DIR=
# Stable secret so sessions survive backend restarts during development.
WIREGATE_SERVER_JWT_SECRET=dev-only-jwt-secret-change-in-production-not-safe

# ── Database ──────────────────────────────────────────────────────────────────
# ../ = repo root (air runs from backend/).
WIREGATE_DATABASE_DSN=../.dev-data/wiregate.db

# ── WireGuard ─────────────────────────────────────────────────────────────────
# Dedicated dev interface — created by scripts/dev-setup.sh, never touches wg0.
WIREGATE_WIREGUARD_INTERFACE=wgdev0
# ../ = repo root; matches where dev-setup.sh writes wgdev0.conf.
WIREGATE_WIREGUARD_CONFIG_DIR=../.dev-data/wireguard
WIREGATE_WIREGUARD_AUTO_APPLY=true
